# Backend
ENVIRONMENT=local
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pulsetradeai
OPENAI_API_KEY=
OPENAI_FAST_MODEL=gpt-5-nano
OPENAI_BRIEF_MODEL=gpt-5-mini
USE_MOCK_AI=true
USE_MOCK_MARKET_DATA=false
SENTIMENT_PROVIDER=lexicon
FINBERT_MODEL=ProsusAI/finbert
FINNHUB_API_KEY=
FINNHUB_RATE_LIMIT_PER_MINUTE=60
FINNHUB_MAX_CALLS_PER_SECOND=30
USE_FINNHUB_NEWS=true
FINNHUB_NEWS_SYMBOLS_PER_POLL=1
FINNHUB_NEWS_LOOKBACK_DAYS=7
FINNHUB_NEWS_MAX_EVENTS_PER_POLL=1
FINNHUB_NEWS_BOOTSTRAP_ON_START=true
FINNHUB_NEWS_BOOTSTRAP_SYMBOL_LIMIT=10
FINNHUB_NEWS_BOOTSTRAP_EVENTS_PER_SYMBOL=1
TRACKED_TICKERS=["AAPL","MSFT","NVDA","TSLA","BTC-USD"]

# Frontend
VITE_API_BASE_URL=
VITE_WS_URL=
